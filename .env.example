==========================================
NodeBB Integration Layer
Environment Configuration Example
==========================================
Application mode

NODE_ENV=development




==========================================
NodeBB
==========================================
NodeBB server address

NODEBB_URL=http://localhost:4567

NodeBB API token (optional)

NODEBB_API_KEY=







==========================================
AI / Embeddings
==========================================
Available:
fake - local test vectors
openai - OpenAI embeddings

AI_PROVIDER=fake

Vector size
text-embedding-3-small = 1536

EMBEDDING_SIZE=1536







==========================================
OpenAI
==========================================
Required only when AI_PROVIDER=openai

OPENAI_API_KEY=

Chat model

OPENAI_MODEL=gpt-4.1-mini

Embedding model

OPENAI_EMBEDDING_MODEL=text-embedding-3-small







==========================================
Qdrant Vector Database
==========================================

QDRANT_URL=http://localhost:6333

QDRANT_COLLECTION=nodebb_knowledge







==========================================
Redis
==========================================

REDIS_HOST=localhost

REDIS_PORT=6379

REDIS_PASSWORD=







==========================================
MCP Server
==========================================
Enable MCP layer

MCP_ENABLED=true

Start MCP automatically

MCP_AUTOSTART=false