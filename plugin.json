{
    "id": "nodebb-plugin-integration",

    "name": "NodeBB Integration Layer",

    "description":
    "AI integration layer with MCP and semantic search",

    "url":
    "https://github.com/Sergey-ek/nodebb-plugin-integration",

    "version":
    "0.1.0",

    "main":
    "library.js",


    "hooks": [

        {
            "hook":
            "static:app.load",

            "method":
            "init"
        },


        {
            "hook":
            "action:post.save",

            "method":
            "onPostCreate"
        },


        {
            "hook":
            "action:topic.save",

            "method":
            "onTopicCreate"
        }

    ]

}