{
  "id": "nodebb-plugin-integration",
  "name": "NodeBB Integration Layer",
  "description": "AI integration layer for NodeBB with MCP, semantic search, RAG and Qdrant knowledge pipeline",
  "library": "./library.js",

  "staticDirs": {
    "public": "public"
  },

  "modules": {
    "admin/plugins/integration.js": "public/js/admin.js"
  },

  "hooks": [
    {
      "hook": "static:app.load",
      "method": "init"
    },
    {
      "hook": "action:post.save",
      "method": "onPostSave"
    },
    {
      "hook": "action:topic.save",
      "method": "onTopicSave"
    },
    {
      "hook": "filter:admin.header.build",
      "method": "addAdminNavigation"
    }
  ]
}